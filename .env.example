# ====================================================================
# 犯罪意图识别框架 — 环境变量配置
# 复制本文件为 .env 并填入真实值；.env 已被 .gitignore 排除，切勿提交
# ====================================================================

# --- Teacher LLM API（Phase 0 造数 / Phase 2 DPO 偏好对生成 / LLM-as-Judge）---
# 支持多个 provider，按需启用；未启用的 provider 对应字段留空即可

# GLM-4-Flash (智谱)
GLM_MODEL_NAME=glm-4.7-flash
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Agnes 2.0 Flash
AGNES_MODEL_NAME=agnes-2.0-flash
AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# 备选：OpenAI 兼容接口（如使用其他代理/中转）
OPENAI_MODEL_NAME=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- HuggingFace（模型下载，非必需；私有/受限模型时填写）---
HF_TOKEN=

# --- 实验跟踪（可选）---
WANDB_API_KEY=
WANDB_PROJECT=criminal-intent

# --- 路径覆盖（可选，默认相对项目根目录）---
# DATA_DIR=data
# RAW_DIR=crawler/output
